{
    "label": "Build Raylib Game",
    "type": "shell",
    "command": "C:/msys64/ucrt64/bin/g++.exe",
    "options": {
        "cwd": "${workspaceFolder}"
    },
    "args": [
        "${file}",
        "-g",
        "-IC:\\raylib\\include",
        "-LC:\\raylib\\lib",
        "-lraylib",
        "-lopengl32",
        "-lgdi32",
        "-lwinmm",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe"
    ],
    "group": {
        "kind": "build",
        "isDefault": true
    },
    "problemMatcher": ["$gcc"]
}