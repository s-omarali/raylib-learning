{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Raylib Game",
            "type": "shell",
            "command": "g++",
            "args": [
                "main.cpp",
                "-IC:\\raylib\\include",
                "-LC:\\raylib\\lib",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-o",
                "game.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}